# Smart WiFi Dashboard - Environment Variables
# Copy this file to .env and update values for your environment.

# Application
APP_NAME=Smart WiFi Dashboard
APP_VERSION=0.1.0
DEBUG=true
SECRET_KEY=your-secret-key-here

# Server
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/smartwifi
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/smartwifi
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=10
REDIS_SESSION_TTL=1800

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT Authentication
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=30

# Rate Limiting
RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_WINDOW_SECONDS=600
BRUTE_FORCE_MAX_ATTEMPTS=20
BRUTE_FORCE_WINDOW_SECONDS=3600
BRUTE_FORCE_BLOCK_SECONDS=1800

# MikroTik Router
ROUTER_CONNECTION_TIMEOUT=5
ROUTER_REQUEST_TIMEOUT=10
ROUTER_MAX_CONNECTIONS_PER_TENANT=5
ROUTER_CONNECTION_QUEUE_TIMEOUT=10

# Encryption (AES-256 key for router password encryption - must be 32 bytes)
ENCRYPTION_KEY=your-32-byte-encryption-key-here!

# Circuit Breaker
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_FAILURE_WINDOW=60
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=30

# AI / Traffic Analysis
NETFLOW_COLLECTION_INTERVAL=60
ANOMALY_BASELINE_DAYS=7
ANOMALY_THRESHOLD_STD=3.0

# Reports
REPORT_MAX_RETENTION_HOURS=24
REPORT_MAX_PER_ADMIN=50
REPORT_MAX_PERIOD_DAYS=30
